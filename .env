# ============================================================
# Copier ce fichier en .env et remplir les valeurs manquantes
# Ne jamais committer le fichier .env
# ============================================================

# --- Application ---------------------------------------------
APP_ENV=development
SECRET_KEY=change-me-in-production
API_KEY_SALT=change-me-in-production

# --- PostgreSQL -----------------------------------------------
POSTGRES_USER=rag
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://rag:ragpassword@postgres:5432/ragdb

# --- Qdrant ---------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# --- Redis / Celery -------------------------------------------
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Fournisseur LLM -----------------------------------------
# "lmstudio" pour un usage local gratuit (LM Studio requis)
# "openai"   pour l'API OpenAI (clé requise)
LLM_PROVIDER=lmstudio

# --- LM Studio (actif si LLM_PROVIDER=lmstudio) --------------
# LM Studio tourne sur la machine hôte.
# Depuis Docker, "host.docker.internal" pointe vers localhost de l'hôte.
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_LLM_MODEL=meta-llama-3.1-8b-instruct
LMSTUDIO_EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5

# --- OpenAI (actif si LLM_PROVIDER=openai) -------------------
OPENAI_API_KEY=
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small

# --- Ingestion -----------------------------------------------
CRAWL_USER_AGENT=CompetitiveRAG/1.0
REQUEST_TIMEOUT_SECONDS=30
MAX_CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- CORS (frontend) -----------------------------------------
FRONTEND_ORIGIN=http://localhost:3000
